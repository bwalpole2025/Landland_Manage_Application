# --- Core ---
# PostgreSQL connection string.
DATABASE_URL="postgresql://landland:landland@localhost:5433/landland?schema=public"
# Name of the session cookie.
SESSION_COOKIE_NAME="landland_session"
# Public base URL (used in verification / reset emails).
APP_URL="http://localhost:3000"

# --- Background jobs (BullMQ) ---
# When unset, the queue is disabled and jobs are no-ops (handy for CI/local).
# REDIS_URL="redis://localhost:6379"

# --- Providers (each has a mock for local development) ---
# bank feed: "mock" | "truelayer" | ...
BANK_FEED_PROVIDER="mock"
# HMRC MTD: "mock" | "hmrc"
HMRC_MTD_PROVIDER="mock"
# document storage: "mock" (local disk) | "s3"
DOCUMENT_STORAGE_PROVIDER="mock"
# mailer: "console" | "smtp" | "ses"
MAILER_PROVIDER="console"
# SMS (mobile verification codes): "console" | "twilio"
SMS_PROVIDER="console"
# Push (mobile/web notifications): "console" | "expo" | "fcm"
PUSH_PROVIDER="console"
# Card billing (hosted checkout — never handles raw card data): "mock" | "stripe"
PAYMENT_PROVIDER="mock"

# --- Encryption at rest ---
# Used to encrypt sensitive columns (TOTP secrets, OAuth tokens) at rest.
# REQUIRED in production (source from a KMS/secrets manager). When unset, values
# are stored as tagged plaintext (dev/CI only) and a warning is logged in prod.
# ENCRYPTION_KEY="a-long-random-secret-string"

# --- S3-compatible object storage (only when DOCUMENT_STORAGE_PROVIDER=s3) ---
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="eu-west-2"
# S3_BUCKET="landland-documents"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# --- Supabase Storage for compliance evidence (StoragePort) ---
# When unset, an in-memory adapter is used (dev/test; not durable). The
# service-role key is server-side only — never expose it to the client.
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_KEY=""
# SUPABASE_STORAGE_BUCKET="evidence"
